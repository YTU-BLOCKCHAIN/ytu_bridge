# Supabase — gerçek değerleri .env.local'a koy (bu dosya commit edilir, placeholder)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM="Bridge <bridge@ytublockchain.com>"
# Supabase "Send Email" auth hook secret — Dashboard → Authentication → Hooks → Send Email
# Format: v1,whsec_...  (auth mailleri /api/auth/send-email üzerinden Resend ile gönderilir)
SEND_EMAIL_HOOK_SECRET=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Admin cüzdanları (virgülle) — bu adresler yönetim yetkisi alır
ADMIN_WALLETS=0x0000000000000000000000000000000000000000
